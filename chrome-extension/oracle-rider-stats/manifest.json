{
  "manifest_version": 3,
  "name": "Oracle Rider Stats",
  "version": "1.0.1",
  "description": "Klik op een renner op Oracle Games en bekijk direct stats uit ProCyclingStats.",
  "host_permissions": [
    "https://www.procyclingstats.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.oracle-games.online/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Oracle Rider Stats",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}
