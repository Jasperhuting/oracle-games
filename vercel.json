{
  "installCommand": "corepack enable && corepack yarn install --immutable",
  "buildCommand": "corepack enable && corepack yarn build",
  "crons": [
    {
      "path": "/api/cron/check-auction-finalizations",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/send-message-notifications",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/check-auction-closing-soon",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/send-budget-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/send-birthday-notifications",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/cleanup-expired-jobs",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/scrape-todays-races",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/process-scrape-jobs",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/close-expired-chats",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/open-scheduled-chats",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/chat-telegram-summary",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scrape-race-calendar",
      "schedule": "0 9 * 1 *"
    },
    {
      "path": "/api/cron/forum-digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/wk-2026-refresh-team-history",
      "schedule": "0 1 * * *"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 60
    },
    "app/api/scraper/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/scrape/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/run-scraper/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/cron/scrape-todays-races/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/cron/process-scrape-jobs/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/jobs/process/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/admin/rescrape-year/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/cron/scrape-race-calendar/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/admin/sync-race-calendar/**/*.ts": {
      "maxDuration": 300
    },
    "app/api/cron/wk-2026-refresh-team-history/**/*.ts": {
      "maxDuration": 300
    }
  }
}
